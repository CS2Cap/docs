{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    ":dependencyDashboard",
    ":semanticCommits"
  ],
  "schedule": ["before 6am on monday"],
  "timezone": "UTC",
  "prConcurrentLimit": 5,
  "prHourlyLimit": 2,
  "rangeStrategy": "bump",
  "lockFileMaintenance": {
    "enabled": true,
    "schedule": ["before 6am on the first day of the month"]
  },
  "vulnerabilityAlerts": {
    "enabled": true,
    "labels": ["security"],
    "schedule": ["at any time"]
  },
  "packageRules": [
    {
      "matchUpdateTypes": ["patch"],
      "matchDepTypes": ["devDependencies"],
      "automerge": true,
      "automergeType": "pr",
      "platformAutomerge": true
    },
    {
      "matchPackageNames": ["next", "react", "react-dom", "@types/react", "@types/react-dom"],
      "groupName": "next + react",
      "schedule": ["before 6am on the first day of the month"]
    },
    {
      "matchPackageNames": ["/^@radix-ui//"],
      "groupName": "radix-ui"
    },
    {
      "matchPackageNames": ["/^@tanstack//"],
      "groupName": "tanstack"
    },
    {
      "matchPackageNames": ["/^@vercel//"],
      "groupName": "vercel"
    },
    {
      "matchPackageNames": ["/^eslint/", "/eslint-/"],
      "groupName": "eslint"
    },
    {
      "matchPackageNames": ["tailwindcss", "/^@tailwindcss//"],
      "groupName": "tailwind"
    },
    {
      "matchUpdateTypes": ["major"],
      "labels": ["dependencies", "major"],
      "minimumReleaseAge": "7 days"
    }
  ]
}
